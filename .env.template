## Wake word
# enable wake word detection. This feature depends on the openwakeword, you need to install the openwakeword 0.6.0 or above and set up the wake word models correctly for it to work.
# WAKE_WORD_ENABLED=true
# if you have setup virtual environment for the wake word python script, you can specify the python binary path here, otherwise it will use "python3" by default
# WAKE_WORD_PYTHON_PATH=/home/pi/.pyenv/versions/python311/bin/python
# Wake word names (comma-separated) or custom model paths (comma-separated)
# WAKE_WORDS=hey_jarvis
# WAKE_WORD_MODEL_PATHS=/path/to/custom.tflite
# Detection threshold and cooldown (seconds)
# WAKE_WORD_THRESHOLD=0.5
# WAKE_WORD_COOLDOWN_SEC=1.5
# Auto listening limits (seconds)
# WAKE_WORD_IDLE_TIMEOUT_SEC=60
# WAKE_WORD_RECORD_MAX_SEC=60
# End conversation keywords (comma-separated, case-insensitive)
# WAKE_WORD_END_KEYWORDS=byebye,goodbye,stop

# specify the image generation server to use, the generated images will be saved in the data/images folder
# options: openai, gemini, volcengine, llm8850lcm
IMAGE_GENERATION_SERVER=openai

# specify the vision model for image understanding tasks
# options: openai, gemini, volcengine, ollama
# VISION_SERVER=ollama

## Pi Camera
# if you want to enable the Pi Camera for image capture (double click the button in idle status to enter) uncomment the following line:
# ENABLE_CAMERA=true
# if your chat model supports image input and you want to use the captured image in chat, uncomment the following line.
# USE_CAPTURED_IMAGE_IN_CHAT=true

## RAG Settings
# Enable RAG (Retrieval-Augmented Generation) by setting the following variable to true
# ENABLE_RAG=true
# specify the embedding server and vector database server to use for RAG, default embedding server is ollama
# options for EMBEDDING_SERVER: ollama
# EMBEDDING_SERVER=ollama
# specify the vector database server to use for RAG, default vector database server is qdrant
# options for VECTOR_DB_SERVER: qdrant
# VECTOR_DB_SERVER=qdrant
# knowledge score threshold for RAG, default is 0.65, score range is 0.0 - 1.0, under this threshold will be considered as no relevant knowledge found
# RAG_KNOWLEDGE_SCORE_THRESHOLD=0.65

### WARNING: enabling knowledge summary will significantly increase the time and cost of knowledge base creation, please use it with caution.
# enable knowledge summary generation when creating knowledge base, default is false. If it is enabled, each knowledge chunk will be summarized using LLM_SERVER before being stored in the vector database.
# supported LLM servers for knowledge summary: ollama, openai, gemini, grok, anthropic, minimax, kimi, qwen, volcengine
# ENABLE_KNOWLEDGE_SUMMARY=false
# specify the prompt prefix for knowledge summary generation
# RAG_KNOWLEDGE_SUMMARY_PROMPT_PREFIX="Please provide a concise summary for the following text in **30 words** or less:"

# specify the chat history reset time in seconds, default is 5 minutes (300 seconds)
# CHAT_HISTORY_RESET_TIME=300

# if you want to clean the data folder on each start, set the following environment variable to true
# CLEAN_DATA_FOLDER_ON_START=true

## Log Mode
# Participant and device identifiers added to every transcript entry.
# Set these in the .env file on each device before a study session.
# PARTICIPANT_ID=P01
# DEVICE_ID=device-01

# How long (in ms) the button must be held to start logging an entry. Default: 1500
# LONG_PRESS_MS=1500

# How long (in ms) the device waits for the user to answer the follow-up before returning to idle. Default: 30000
# FOLLOWUP_WAIT_TIMEOUT_MS=30000

# After transcription, POST each log entry as JSON to this URL (for the university VM pipeline).
# The payload shape: { timestamp, date, type: "log"|"followup", transcript }
# TRANSCRIPT_ENDPOINT=https://aibuddy.ifi.uzh.ch/logs

# End-of-day prompt: set the time (24h HH:MM) at which the device will play the EOD prompt.
# Default is 17:00 (5pm). Set EOD_PROMPT_ENABLED=false to disable.
# EOD_PROMPT_TIME=17:00
# EOD_PROMPT_ENABLED=true

# enable or disable thinking of LLM
# if you are using ollama as LLM server, please confirm that the model supports thinking before enabling this option
# otherwise the ollama will return a 400 error
ENABLE_THINKING=true


