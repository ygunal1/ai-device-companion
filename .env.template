# specify the ASR、LLM and TTS server to use
# options: test, openai, gemini, tencent, volcengine, whisper, whisper-http, vosk, llm8850whisper, faster-whisper, hailowhisper, picovoice
ASR_SERVER=test

# options: test, openai, gemini, grok, anthropic, minimax, kimi, qwen, volcengine, ollama, llm8850, whisplay-im, image-tool-direct, perplexity, openrouter
LLM_SERVER=test

# options: test, openai, gemini, tencent, volcengine, piper, piper-http, espeak-ng, llm8850melotts, supertonic, picovoice
