## Perplexity
# if you are using Perplexity as LLM server, please set the following environment variables
# Documentation: https://docs.perplexity.ai
PERPLEXITY_API_KEY=your_perplexity_api_key
# The default model is sonar. For web-search reasoning, try sonar-reasoning or sonar-pro.
# PERPLEXITY_LLM_MODEL=sonar
# Enable tool/function calling. Only supported on select models (e.g. sonar-pro). Default is false.
# PERPLEXITY_ENABLE_TOOLS=false

## Picovoice (Leopard ASR + Orca TTS)
# if you are using Picovoice as ASR (ASR_SERVER=picovoice) or TTS (TTS_SERVER=picovoice), please set the following variables
# Get your free AccessKey at https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your_picovoice_access_key
# Optional: path to a custom Leopard model file (.pv). Leave unset to use the default en model.
# PICOVOICE_LEOPARD_MODEL_PATH=/path/to/leopard_params.pv
# Optional: path to a custom Orca model file (.pv). Leave unset to use the default en female model.
# PICOVOICE_ORCA_MODEL_PATH=/path/to/orca_params.pv

## Default Emoji
# The default emoji shown on the display (e.g. during listening). Must be a valid emoji, otherwise falls back to 😐.
# DEFAULT_EMOJI=😐

## Custom font for displaying text on screen
# CUSTOM_FONT_PATH=/path/to/your/font.ttf

## Initial Volume Level
# specify the initial volume level (0-127) when the chatbot starts
# value mapped to ALSA volume levels # 60% = 114  80% = 121  90% = 124
# INITIAL_VOLUME_LEVEL=114

## Local Music Tool (LLM function calling)
# Comma-separated local folders for music search. Absolute paths are recommended.
# Example: MUSIC_LIBRARY_DIRS=/home/pi/Music,/mnt/usb/music
# MUSIC_LIBRARY_DIRS=
# Supported file extensions for local music search.
# MUSIC_FILE_EXTENSIONS=mp3,wav,flac,m4a,aac,ogg
# Fuzzy-match score threshold (0.0-1.0). Higher value means stricter matching.
# MUSIC_FUZZY_MIN_SCORE=0.35
# Rescan interval for music library index in seconds.
# MUSIC_RESCAN_SECONDS=60

## Qdrant for RAG Vector Database
# if you are using Qdrant as the vector database server for RAG, please set the following environment variables, the default host is http://localhost:6333
# QDRANT_HOST=http://localhost:6333

## Web Display Settings
# This is an optional web-based display stimulating the Whisplay HAT screen, LED and button. It's disabled by default.
# WHISPLAY_WEB_ENABLED=true
# WHISPLAY_WEB_PORT=17880
# WHISPLAY_WEB_HOST=0.0.0.0

## Web Audio Settings (requires WHISPLAY_WEB_ENABLED=true)
# When enabled, the browser microphone is used for recording instead of the device ALSA input,
# and TTS audio is played back through the browser speaker instead of the ALSA output.
# This is useful when running on a desktop or accessing the web display remotely.
# Note: for ASR servers that require WAV/MP3 (e.g. vosk, local whisper), ffmpeg must be
# available on the host to convert the browser's webm/opus recording automatically.
# Most cloud ASR servers (openai, gemini, volcengine, etc.) accept webm directly.
# WEB_AUDIO_ENABLED=true

## Web Camera Settings (requires WHISPLAY_WEB_ENABLED=true)
# When enabled, the browser's camera is used for photo capture instead of the Pi camera module.
# This is useful when running on a desktop/laptop or accessing the web display remotely.
# WEB_CAMERA_ENABLED=true

## MemPalace (Long-term AI Memory)
# MemPalace stores conversation memories locally using ChromaDB and provides semantic search.
# Install: pip install mempalace
# Init:    mempalace init ~/path/to/project
# Mine:    mempalace mine ~/chats/ --mode convos
# Docs:    https://github.com/MemPalace/mempalace
# MEMPALACE_ENABLED=true
# Path to the palace data directory (default: ~/.mempalace/palace)
# MEMPALACE_PALACE_PATH=~/.mempalace/palace
# Python binary that has mempalace installed (default: python3)
# MEMPALACE_PYTHON_PATH=python3
# Maximum search results returned per query (default: 5)
# MEMPALACE_MAX_RESULTS=5
# Default wing for search/store when none is specified
# MEMPALACE_DEFAULT_WING=
# Auto-save every conversation exchange to long-term memory (default: true when enabled)
# Set to false to only use manual mempalaceStore tool calls
# MEMPALACE_AUTO_SAVE=true
